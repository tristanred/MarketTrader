# ──────────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────────
# Default: ./dev.db — a relative path is resolved against the server package,
# so the file lives at packages/server/dev.db (the server runs with that CWD).
# PostgreSQL (production / Docker):
# DATABASE_URL=postgres://markettrader:markettrader@localhost:5432/markettrader
# SQLite (development — no Docker needed):
DATABASE_URL=./dev.db

# ──────────────────────────────────────────────────────────────────────
# Auth (required)
# ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-random-64-char-hex-string

# ──────────────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────────────
# Default: 3000
PORT=3000
# One of: development | production | test. Default: development
NODE_ENV=development

# ──────────────────────────────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────────────────────────────
# Exact-match origin allowed for credentialed requests. Default: http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ──────────────────────────────────────────────────────────────────────
# Stock data provider
# ──────────────────────────────────────────────────────────────────────
# One of: yahoo | alpaca. Default: yahoo (no API key required)
STOCK_PROVIDER=yahoo

# Required only when STOCK_PROVIDER=alpaca (or MARKET_STATUS_PROVIDER=alpaca).
# Both the key ID and the secret are required — Alpaca rejects requests that
# omit the secret. (ALPACA_API_KEY is still accepted as an alias for the ID.)
# ALPACA_API_KEY_ID=your-alpaca-key-id-here
# ALPACA_API_SECRET_KEY=your-alpaca-secret-here

# ──────────────────────────────────────────────────────────────────────
# Error reporting (optional)
# ──────────────────────────────────────────────────────────────────────
# When set, the server initializes @sentry/node and forwards 5xx errors.
# Empty / unset disables Sentry entirely (no-op).
# SENTRY_DSN=https://public@sentry.io/project-id

# ──────────────────────────────────────────────────────────────────────
# Market-status provider (whether the chart should extend live ticks)
# ──────────────────────────────────────────────────────────────────────
# One of: yahoo | alpaca | static.
# When unset, defaults to MATCH the active STOCK_PROVIDER above — so
# swapping the price provider doesn't silently break the chart's
# market-hours gating. Set to `static` for an offline, no-key fallback
# that uses the bundled NYSE-holiday calendar plus wall-clock math.
# MARKET_STATUS_PROVIDER=static

# In-memory cache TTL for /market/status responses. Sessions change at
# well-known clock boundaries so 60s is more than enough.
# MARKET_STATUS_CACHE_TTL_MS=60000

# ──────────────────────────────────────────────────────────────────────
# Stock data resilience — cache TTLs
# ──────────────────────────────────────────────────────────────────────
# All durations are in milliseconds. Defaults shown below are applied
# automatically when the variable is unset; uncomment to override.

# DB-backed quote cache TTL. Cache hits within this window skip the upstream
# fetch entirely. Larger values reduce upstream pressure under bursty load.
# STOCK_CACHE_TTL_MS=60000

# In-memory search-result cache TTL, keyed on the lowercased query.
# Autocomplete repeats within this window are served from memory.
# STOCK_SEARCH_CACHE_TTL_MS=300000

# In-memory history cache TTL, keyed on (symbol, range). Chart pages
# repeatedly mount/unmount; caching keeps Yahoo calls predictable.
# STOCK_HISTORY_CACHE_TTL_MS=60000

# ──────────────────────────────────────────────────────────────────────
# Stock data resilience — rate-limit handling
# ──────────────────────────────────────────────────────────────────────

# After an upstream 429, the provider refuses to call out for this long.
# Surfaces to clients as the `Retry-After` header on 429 responses.
# STOCK_RATE_LIMIT_BACKOFF_MS=60000

# When the upstream is rate-limited, the cached-provider falls back to a
# cached quote if its row is no older than this. Older rows propagate
# the RATE_LIMITED error instead.
# STOCK_STALE_PRICE_MAX_AGE_MS=300000

# ──────────────────────────────────────────────────────────────────────
# Stock data resilience — stale trades
# ──────────────────────────────────────────────────────────────────────

# When true, the trade endpoint will execute orders at the most recent
# cached price if the live quote is rate-limited (subject to the max
# age below). Default: false — operators who prefer fairness over
# availability should leave this off.
# STOCK_ALLOW_STALE_TRADES=false

# Trades using a cached price older than this are rejected with
# `409 STALE_PRICE_TOO_OLD` even when stale trades are enabled.
# STOCK_STALE_TRADE_MAX_AGE_MS=300000

# ──────────────────────────────────────────────────────────────────────
# Market-hours trading gate
# ──────────────────────────────────────────────────────────────────────

# How the trade endpoint handles orders submitted while the market is closed:
#   instant  — fill immediately at the last known price (default, legacy).
#   disabled — reject with 409 MARKET_CLOSED.
#   pending  — queue the order, reserve cash (buys) or shares (sells), and
#              settle at next market open using a freshly-fetched quote.
# MARKET_HOURS_MODE=instant

# When true, PRE and POST sessions count as "open" for the gate above.
# Default: false (only REGULAR 9:30–16:00 ET counts as open).
# MARKET_HOURS_INCLUDE_EXTENDED=false

# Settlement-worker tick interval (ms). Only runs when MARKET_HOURS_MODE=pending.
# PENDING_ORDERS_TICK_MS=30000

# ──────────────────────────────────────────────────────────────────────
# SQLite concurrency (ignored when DATABASE_URL is postgres://)
# ──────────────────────────────────────────────────────────────────────

# Per-connection PRAGMA busy_timeout in ms — how long a writer waits for a
# contended lock before erroring. File-based SQLite also runs in WAL mode so
# readers and the writer don't block each other (lets the API keep serving
# while a write job such as `pnpm seed:history` runs against the same file).
# SQLITE_BUSY_TIMEOUT_MS=5000
