{
  "name": "markettrader",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter './packages/*' dev",
    "build": "pnpm --filter shared build && pnpm --parallel --filter 'server frontend' build",
