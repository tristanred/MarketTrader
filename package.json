{
  "name": "markettrader",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "node scripts/bootstrap-dev.mjs && pnpm -r --parallel dev",
    "bootstrap": "node scripts/bootstrap-dev.mjs",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @markettrader/shared build",
    "test": "pnpm build:shared && pnpm -r test",
    "typecheck": "pnpm build:shared && pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "e2e": "pnpm --filter frontend e2e",
    "seed:history": "pnpm --filter @markettrader/tools-seed-game-history start",
    "docs:achievements": "pnpm --filter @markettrader/frontend exec node ./scripts/generate-achievement-docs.mjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
