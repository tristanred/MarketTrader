{
  "name": "markettrader",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "node scripts/bootstrap-dev.mjs && pnpm -r --parallel dev",
    "bootstrap": "node scripts/bootstrap-dev.mjs",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "e2e": "pnpm --filter frontend e2e"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.4.2"
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
