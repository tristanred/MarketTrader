    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@fastify/websocket": "^11.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "@libsql/client": "^0.14.0",
    "@markettrader/shared": "workspace:*",
    "@node-rs/argon2": "^2.0.0",
    "@sentry/node": "^10.52.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "nyse-holidays": "^1.2.0",
    "postgres": "^3.4.0",
    "yahoo-finance2": "^3.14.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.29.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0",
    "ws": "^8.20.0"
